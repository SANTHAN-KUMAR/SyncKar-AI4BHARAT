# ─── Kafka ───
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
# For Aiven (deployed):
# KAFKA_SECURITY_PROTOCOL=SASL_SSL
# KAFKA_SASL_MECHANISM=PLAIN
# KAFKA_SASL_USERNAME=avnadmin
# KAFKA_SASL_PASSWORD=<from-aiven-dashboard>
# KAFKA_SSL_CA_PATH=/tmp/ca.pem
# KAFKA_SSL_CA_PEM_BASE64=<base64 of Aiven ca.pem (no newlines)>
# (Alternative) KAFKA_SSL_CA_PEM="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----\n"

# ─── PostgreSQL ───
DATABASE_URL=postgresql://synckar_app:synckar_app@localhost:5432/synckar
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0

# ─── RSA Signing (BSA 2023) ───
RSA_PRIVATE_KEY_PATH=./keys/private.pem
RSA_PUBLIC_KEY_PATH=./keys/public.pem

# ─── Mock System URLs ───
# Local dev (three separate processes):
# MOCK_SWS_BASE_URL=http://localhost:8000
# MOCK_SHOP_BASE_URL=http://localhost:8001
# MOCK_FACTORIES_BASE_URL=http://localhost:8002

# Railway / combined mock service (all mocks on one host, different prefixes):
MOCK_SWS_BASE_URL=http://mock-systems:8000/sws
MOCK_SHOP_BASE_URL=http://mock-systems:8000/shop
MOCK_FACTORIES_BASE_URL=http://mock-systems:8000/factories

# ─── Pipeline Config ───
CONFLICT_WINDOW_SECONDS=900
IDEMPOTENCY_TTL_SECONDS=259200
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_WINDOW_SECONDS=120
CIRCUIT_BREAKER_PROBE_INTERVAL_SECONDS=60
CONSUMER_TASK_TIMEOUT_SECONDS=30
LOOP_GUARD_TTL_SECONDS=900
WEBHOOK_RATE_LIMIT_PER_MINUTE=60

# ─── Polling Intervals ───
SWS_POLL_INTERVAL_SECONDS=5
SHOP_POLL_INTERVAL_SECONDS=10
FACTORIES_POLL_INTERVAL_SECONDS=10

# ─── Celery ───
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
